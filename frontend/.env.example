# Soundcheck frontend env. Copy to .env.local and fill in.
# Generate AUTH_SECRET with:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Hosted Postgres (Neon / Supabase / Vercel Postgres) — auth + per-user runs.
# e.g. postgres://user:pass@host/db?sslmode=require
DATABASE_URL=

# Google OAuth client (Web application).
# Authorized redirect URI (dev): http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Backend (BFF) base.
NEXT_PUBLIC_BFF_URL=http://localhost:8000
