# Soundcheck environment — copy to .env and fill in. NEVER commit .env.

# Band platform (defaults are production; appendix §0)
THENVOI_REST_URL=https://app.band.ai/
THENVOI_WS_URL=wss://app.band.ai/api/v1/socket/websocket

# Model providers — no paid Anthropic/OpenAI accounts (CLAUDE.md / appendix §6)
AIMLAPI_API_KEY=            # https://api.aimlapi.com/v1 — frontier lane (Claude/GPT/Gemini)
FEATHERLESS_API_KEY=        # https://api.featherless.ai/v1 — open-source high-volume lane

# Optional free third lane
GEMINI_API_KEY=

# GitHub — scoped to the target repo only (repo + PR)
GITHUB_TOKEN=

# Human API key for the BFF (Band Settings > API Keys) — needed from P4
THENVOI_HUMAN_API_KEY=

# Postgres projection (read-only cache for the UI; P4)
DATABASE_URL=postgresql://soundcheck:soundcheck@localhost:5432/soundcheck

# Do NOT set ANTHROPIC_API_KEY / OPENAI_API_KEY to paid accounts.
